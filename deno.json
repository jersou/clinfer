{
  "name": "@jersou/clinfer",
  "version": "0.9.7",
  "exports": "./mod.ts",
  "license": "MIT",
  "tasks": {
    "fmt": "deno fmt --ignore=tmp,.cov_profile,src/test-data/bad-config.json,node,docs/docsify,docs/clinfer.svg",
    "check": "deno check mod.ts",
    "gen-cov": "./gen-cov.ts",
    "gen-cov-watch": "deno run -A --watch=mod.ts,mod.test.ts,src/ gen-cov.ts",
    "lint": "deno lint --ignore=tmp,.cov_profile,docs/examples,node,docs/docsify",
    "pre-commit": "deno task fmt --check && deno task lint && deno task test && deno task check",
    "publish-dry-run": "deno publish --dry-run",
    "test": "deno test -A --ignore=tmp,.cov_profile,node,docs/docsify --quiet",
    "test-watch": "deno test -A --watch --ignore=tmp,.cov_profile,node --quiet",
    "run-example": "deno run docs/examples/full-example-with-decorators.ts --help",
    "bench": "deno bench docs/examples/bench.ts",
    "update-changelog": "conventional-changelog -p conventionalcommits --same-file -i docs/CHANGELOG.md -k deno.json && deno task fmt",
    "serve-docsify": "deno run --allow-net --allow-read jsr:@std/http/file-server -v docs"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.30/parse-args",
    "@std/collections": "jsr:@std/collections@^1.2.0",
    "@std/fmt/colors": "jsr:@std/fmt@1.0.10/colors",
    "@std/text": "jsr:@std/text@1.0.19",
    "clinfer": "./mod.ts"
  },
  "lint": {
    "rules": {
      "exclude": ["no-import-prefix"]
    }
  }
}
